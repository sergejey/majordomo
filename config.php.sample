 */
//define('DISABLE_WEBSOCKETS', 1);             // Полностью отключить websocket-цикл
//define('SETTINGS_SYSTEM_WEBSOCKETS_RESTART_TIMEOUT', 300); // Watchdog websocket (сек), 0 - отключить
define('WEBSOCKETS_HOST', '0.0.0.0');          // Адрес bind для websocket-сервера
define('WEBSOCKETS_PORT', 8002);               // Порт websocket-сервера
define('WEBSOCKETS_TLS', 0);                   // Использовать TLS: 0 — нет, 1 — да
define('WEBSOCKETS_MAX_CLIENTS', 100);         // Общий лимит одновременных websocket-клиентов
define('WEBSOCKETS_MAX_CONNECTIONS_PER_IP', 100); // Лимит подключений с одного IP
define('WEBSOCKETS_MAX_REQUESTS_PER_MINUTE', 20000); // Лимит сообщений/запросов в минуту на клиента
define('WEBSOCKETS_CLIENT_TIMEOUT', 30);       // Таймаут неактивного клиента в секундах
define('WEBSOCKETS_CHECK_ORIGIN', 0);          // Проверять Origin в handshake: 0/1
define('WEBSOCKETS_ALLOWED_ORIGINS', '');      // Белый список Origin (через запятую), если CHECK_ORIGIN=1

// TLS-параметры (используются только если WEBSOCKETS_TLS=1)
define('WEBSOCKETS_TLS_PEM_FILE', './server.pem');       // Путь к PEM-сертификату
define('WEBSOCKETS_TLS_PEM_PASSPHRASE', 'shinywss');     // Пароль PEM-ключа
define('WEBSOCKETS_TLS_ALLOW_SELF_SIGNED', 1);           // Разрешать self-signed сертификаты: 0/1
define('WEBSOCKETS_TLS_VERIFY_PEER', 0);                 // Проверять TLS peer: 0/1
define('WEBSOCKETS_TLS_VERIFY_PEER_NAME', 0);            // Проверять имя TLS peer: 0/1
